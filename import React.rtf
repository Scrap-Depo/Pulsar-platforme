\par       \{liveTab === 'multiple' && <div className="w-full h-full p-12 lg:p-24"><ProjectorMultiple mcQuestion=\{props.mcQuestion\} mcOptions=\{props.mcOptions\} standalone=\{true\} /></div>\}

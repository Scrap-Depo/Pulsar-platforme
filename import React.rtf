\par           <div className="flex flex-col gap-8 p-4 lg:p-10">
\par             \{phrasesList?.map(p => (
\par               <div key=\{p.id\} className=\{`glass-card rounded-[2.5rem] p-8 lg:p-12 flex justify-between items-center gap-8`\}>
\par                 <p className="text-white text-2xl lg:text-4xl font-bold leading-tight flex-1 tracking-tight drop-shadow-md">"\{p.text\}"</p>
\par                 \{p.likes > 0 && (
\par                   <div className="flex flex-col items-center bg-black/40 p-5 rounded-[2rem] border border-white/10 shadow-inner shrink-0 min-w-[100px]">
\par                     <Heart size=\{32\} className="text-[#c03654] fill-[#c03654] mb-2 drop-shadow-[0_0_15px_rgba(192,54,84,0.5)]"/>
\par                     <span className="text-3xl font-black text-white">\{p.likes\}</span>
\par                   </div>
\par                 )\}
\par               </div>
\par             ))\}
\par           </div>
\par           <div className="flex flex-col gap-8 p-4 lg:p-10 opacity-60">
\par             \{phrasesList?.map(p => (
\par               <div key=\{`d-$\{p.id\}`\} className=\{`glass-card rounded-[2.5rem] p-8 lg:p-12 flex justify-between items-center gap-8`\}>
\par                 <p className="text-white text-2xl lg:text-4xl font-bold leading-tight flex-1 tracking-tight drop-shadow-md">"\{p.text\}"</p>
\par                 \{p.likes > 0 && (
\par                   <div className="flex flex-col items-center bg-black/40 p-5 rounded-[2rem] border border-white/10 shadow-inner shrink-0 min-w-[100px]">
\par                     <Heart size=\{32\} className="text-[#c03654] fill-[#c03654] mb-2 drop-shadow-[0_0_15px_rgba(192,54,84,0.5)]"/>
\par                     <span className="text-3xl font-black text-white">\{p.likes\}</span>
\par                   </div>
\par                 )\}
\par               </div>
\par             ))\}
\par           </div>
\par         </div>
\par       </div>
\par     </div>
\par   );
\par \}

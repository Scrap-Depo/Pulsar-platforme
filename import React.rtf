\par // === PROJECTOR MODULES ===
\par 
\par }{\rtlch\fcs1 \af31507 \ltrch\fcs0 \f31569\insrsid14887707 // \'cf\'d0\'ce\'c5\'ca\'d2\'ce\'d0: \'c3\'ce\'cb\'ce\'d1\'ce\'c2\'c0\'cd\'c8\'c5 (MULTIPLE CHOICE)
\par }{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid14887707 function ProjectorMultiple(\{ mcQuestion, mcOptions, standalone = false \}) \{
\par   const totalVotes = mcOptions.reduce((sum, opt) => sum + opt.votes, 0);
\par   const sortedOptions = [...mcOptions].sort((a, b) => b.votes - a.votes);
\par 
\par   return (
\par     <div className="w-full h-full relative flex flex-col items-center justify-center max-w-5xl mx-auto">
\par       <div className="mb-12 lg:mb-20 text-center relative z-10 w-full">
\par         <h1 className=\{`$\{standalone ? 'text-5xl lg:text-7xl' : 'text-3xl lg:text-4xl'\} font-black text-white leading-tight tracking-tight drop-shadow-2xl`\}>
\par           \{mcQuestion\}
\par         </h1>
\par         <p className="mt-4 text-[#b7bfe0] font-bold uppercase tracking-[0.3em] text-sm bg-white/5 inline-block px-4 py-2 rounded-full border border-white/10 backdrop-blur-md">
\par }{\rtlch\fcs1 \af31507 \ltrch\fcs0 \f31569\insrsid14887707           \'c2\'f1\'e5\'e3\'ee \'e3\'ee\'eb\'ee\'f1\'ee\'e2: \{totalVotes\}
\par }{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid14887707         </p>
\par       </div>
\par 
\par       <div className="w-full space-y-6 lg:space-y-8 relative z-10">
\par         \{sortedOptions.map((opt, index) => \{
\par           const percentage = totalVotes === 0 ? 0 : Math.round((opt.votes / totalVotes) * 100);
\par           
\par           return (
\par             <div key=\{opt.id\} className="relative w-full glass-card rounded-2xl p-6 flex flex-col justify-center overflow-hidden">
\par               <div className=\{`absolute left-0 top-0 bottom-0 bg-gradient-to-r $\{opt.color\} opacity-40 transition-all duration-1000 ease-out`\} style=\{\{ width: `$\{percentage\}%` \}\}>
\par                 <div className="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] mix-blend-overlay opacity-20"></div>
\par                 <div className="absolute right-0 top-0 bottom-0 w-1 bg-white/50 blur-[2px]"></div>
\par               </div>
\par 
\par               <div className="relative z-10 flex justify-between items-center gap-4">
\par                 <div className="flex items-center gap-6 flex-1 min-w-0">
\par                   <div className=\{`w-10 h-10 lg:w-14 lg:h-14 rounded-xl lg:rounded-2xl bg-gradient-to-br $\{opt.color\} flex items-center justify-center text-white font-black text-lg lg:text-2xl shadow-lg shrink-0`\}>
\par                     \{index + 1\}
\par                   </div>
\par                   <span className="text-xl lg:text-3xl font-bold text-white truncate drop-shadow-md">
\par                     \{opt.text\}
\par                   </span>
\par                 </div>
\par                 
\par                 <div className="flex items-baseline gap-2 shrink-0">
\par                   <span className="text-4xl lg:text-5xl font-black text-white drop-shadow-[0_0_15px_rgba(255,255,255,0.4)]">
\par                     \{percentage\}%
\par                   </span>
\par                   <span className="text-[#829ad4] font-bold text-sm lg:text-base hidden sm:block">
\par                     (\{opt.votes\})
\par                   </span>
\par                 </div>
\par               </div>
\par             </div>
\par           );
\par         \})\}
\par       </div>
\par     </div>
\par   );
\par \}
\par 
\par }{\rtlch\fcs1 \af31507 \ltrch\fcs0 \f31569\insrsid14887707 // \'cf\'d0\'ce\'c5\'ca\'d2\'ce\'d0: \'ce\'d2\'ca\'d0\'db\'d2\'db\'c5 \'ce\'d2\'c2\'c5\'d2\'db
\par }{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid14887707 function ProjectorOpen(\{ phrasesList, focusedId, setFocusedId, particles, standalone = false \}) \{
\par   const focusedPhrase = focusedId ? phrasesList?.find(p => p.id === focusedId) : null;
\par 
\par   return (
\par     <div className="w-full h-full relative">
\par       <div className="absolute inset-0 z-40 pointer-events-none overflow-hidden">
\par         \{particles?.map(p => <div key=\{p.id\} className="absolute bottom-0 text-5xl lg:text-7xl animate-particle drop-shadow-[0_0_30px_rgba(192,54,84,0.6)]" style=\{\{ left: `$\{p.left\}%` \}\}>}{\rtlch\fcs1 \af67 \ltrch\fcs0 \f67\insrsid14887707 

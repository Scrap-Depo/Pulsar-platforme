\par            <button onClick=\{() => setFocusedId(null)\} className="absolute top-8 right-8 p-4 bg-white/10 hover:bg-white/20 rounded-full transition-colors z-[60] text-white/60 hover:text-white shadow-xl"><X size=\{32\} /></button>
\par          </div>
\par       )\}
\par 
\par       <div className="absolute top-0 inset-x-0 h-40 bg-gradient-to-b from-[#0a0a21]/80 to-transparent z-20 pointer-events-none"></div>
\par       <div className="absolute bottom-0 inset-x-0 h-40 bg-gradient-to-t from-[#0a0a21]/80 to-transparent z-20 pointer-events-none"></div>
